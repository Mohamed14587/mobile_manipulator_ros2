<?xml version="1.0"?>
<robot name="assem1_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="pkg_name" value="assem1_description"/>

  <material name="base_color"><color rgba="0.776 0.757 0.737 1"/></material>
  <material name="arm_red"><color rgba="0.988 0.082 0 1"/></material>

  <link name="world" />
  <joint name="world_to_base_joint" type="fixed">
    <parent link="world" /><child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.2" rpy="0 0 0"/><mass value="36.0"/><inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://${pkg_name}/meshes/base_link.STL"/></geometry>
      <material name="base_color"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://${pkg_name}/meshes/base_link.STL"/></geometry>
    </collision>
  </link>

  <link name="armlink1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://${pkg_name}/meshes/armlink1.STL"/></geometry>
      <material name="arm_red"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://${pkg_name}/meshes/armlink1.STL"/></geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <origin xyz="0 0.07 0.5" rpy="0 0 0"/>
    <parent link="base_link"/><child link="armlink1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.2" upper="1.2" effort="100" velocity="3"/>
  </joint>

  <link name="armlink2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/><mass value="1.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry><mesh filename="package://${pkg_name}/meshes/armlink2.STL"/></geometry>
      <material name="arm_red"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://${pkg_name}/meshes/armlink2.STL"/></geometry>
    </collision>
  </link>

  <joint name="joint_2" type="revolute">
    <origin xyz="0 0.196 -0.02" rpy="0 0 0"/> 
    <parent link="armlink1"/><child link="armlink2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.8" upper="2.8" effort="100" velocity="3"/>
  </joint>

</robot>