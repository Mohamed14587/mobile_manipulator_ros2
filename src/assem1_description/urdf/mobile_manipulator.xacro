<?xml version="1.0" encoding="utf-8"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="silver"><color rgba="0.776 0.756 0.737 1" /></material>
  <material name="dark_gray"><color rgba="0.3 0.3 0.3 1" /></material>
  <material name="red_arm"><color rgba="0.988 0.082 0 1" /></material>

  <link name="base_footprint"/>

  <link name="support_left">
    <inertial>
      <mass value="5.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><box size="0.6 0.3 0.15"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="0.6 0.3 0.15"/></geometry>
    </collision>
  </link>

  <joint name="support_left_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="support_left"/>
    <origin xyz="0.3 0.0 0.075" rpy="0 0 1.57"/>
  </joint>

  <link name="support_right">
    <inertial>
      <mass value="5.0"/><inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry><box size="0.6 0.3 0.15"/></geometry>
      <material name="dark_gray"/>
    </visual>
    <collision>
      <geometry><box size="0.6 0.3 0.15"/></geometry>
    </collision>
  </link>

  <joint name="support_right_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="support_right"/>
    <origin xyz="-0.3 0.0 0.075" rpy="0 0 1.57"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.00155 0.0167 0.196" rpy="0 0 0" />
      <mass value="36.7025" />
      <inertia ixx="1.1928" ixy="-3.518E-06" ixz="1.993E-07" iyy="1.3331" iyz="0.00419" izz="1.3514" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1_description/meshes/base_link.STL" /></geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://assem1_description/meshes/base_link.STL" /></geometry>
    </collision>
  </link>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.304" rpy="0 0 0"/>
  </joint>

  <link name="Armlink1">
    <inertial>
      <origin xyz="0.00032 0.106 0.008" rpy="0 0 0" />
      <mass value="0.3325" />
      <inertia ixx="0.00125" ixy="0" ixz="0" iyy="6.2E-05" iyz="0" izz="0.00131" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1_description/meshes/Armlink1.STL"/></geometry>
      <material name="red_arm"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://assem1_description/meshes/Armlink1.STL"/></geometry>
    </collision>
  </link>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0.069976 0.4897" rpy="0 0 0" />
    <parent link="base_link"/>
    <child link="Armlink1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="0.785" effort="10.0" velocity="1.0" />
  </joint>

  <link name="armlink2">
    <inertial>
      <origin xyz="-0.00037 -0.094 -0.009" rpy="0 0 0" />
      <mass value="0.3007" />
      <inertia ixx="0.000749" ixy="0" ixz="0" iyy="7.2E-05" iyz="0" izz="0.000789" />
    </inertial>
    <visual>
      <geometry><mesh filename="package://assem1_description/meshes/armlink2.STL"/></geometry>
      <material name="red_arm"/>
    </visual>
    <collision>
      <geometry><mesh filename="package://assem1_description/meshes/armlink2.STL"/></geometry>
    </collision>
  </link>

  <joint name="joint2" type="revolute">
    <origin xyz="0.00077 0.19499 -0.0168" rpy="0 0 0" />
    <parent link="Armlink1"/>
    <child link="armlink2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10.0" velocity="1.0" />
  </joint>

  <gazebo reference="support_left"><static>true</static></gazebo>
  <gazebo reference="support_right"><static>true</static></gazebo>

</robot>