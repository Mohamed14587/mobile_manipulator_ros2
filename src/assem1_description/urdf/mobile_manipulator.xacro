<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <material name="silver"><color rgba="0.776 0.756 0.737 1" /></material>
  <material name="dark_gray"><color rgba="0.3 0.3 0.3 1" /></material>
  <material name="red_arm"><color rgba="0.988 0.082 0 1" /></material>

  <link name="world" />

  <joint name="world_to_base_joint" type="fixed">
    <parent link="world" />
    <child link="base_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://assem1_description/meshes/base_link.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://assem1_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="arm_link1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://assem1_description/meshes/Armlink1.STL"/>
      </geometry>
      <material name="red_arm"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://assem1_description/meshes/Armlink1.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="arm_link2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://assem1_description/meshes/armlink2.STL"/>
      </geometry>
      <material name="red_arm"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://assem1_description/meshes/armlink2.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="joint_1" type="revolute">
    <origin xyz="0 0.07 0.5" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="arm_link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.785" upper="0.785" effort="100" velocity="3"/>
  </joint>

  <joint name="joint_2" type="revolute">
    <origin xyz="0 0.196 -0.02" rpy="0 0 0"/>
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="3"/>
  </joint>

</robot>