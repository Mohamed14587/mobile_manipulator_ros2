int x = 0;

void setup() {
  // بدء التواصل التسلسلي بسرعة 115200
  Serial.begin(115200);
  // تحديد وقت انتظار البيانات (اختياري في هذا الكود لأننا نرسل فقط)
  Serial.setTimeout(1);
}

void loop() {
  // طباعة قيمة x الحالية ثم الانتقال لسطر جديد
  Serial.println(x);
  
  // زيادة قيمة x بمقدار 1
  x++;

  // تأخير زمني (ملاحظة: delay تأخذ أرقاماً صحيحة بالمللي ثانية)
  delay(100); 
}