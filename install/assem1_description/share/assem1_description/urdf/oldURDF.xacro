<?xml version="1.0"?>
<robot name="assem1_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

<!-- ================= WORLD ================= -->
<link name="world"/>

<!-- ================= BASE ================= -->
<link name="base_link">

  <inertial>
    <origin xyz="-0.00155 -0.01673 0.19606"/>
    <mass value="36.7"/>
    <inertia ixx="1.19" ixy="0" ixz="0"
             iyy="1.33" iyz="0"
             izz="1.35"/>
  </inertial>

  <visual>
    <geometry>
      <mesh filename="package://assem1_description/meshes/base_link.STL"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <mesh filename="package://assem1_description/meshes/base_link.STL"/>
    </geometry>
  </collision>

</link>

<!-- ================= SUPPORT ================= -->

<link name="support">

  <inertial>
    <mass value="5"/>
    <inertia ixx="0.05" ixy="0" ixz="0"
             iyy="0.05" iyz="0"
             izz="0.05"/>
  </inertial>

  <visual>
    <geometry>
      <box size="0.6 0.3 0.15"/>
    </geometry>
  </visual>

</link>

<joint name="support_joint" type="fixed">
  <parent link="world"/>
  <child link="support"/>
  <origin xyz="0 0 0"/>
</joint>

<joint name="base_joint" type="fixed">
  <parent link="support"/>
  <child link="base_link"/>
  <origin xyz="0 0 0.3"/>
</joint>

<!-- ================= ARM LINK 1 ================= -->

<link name="Armlink1">

  <inertial>
    <mass value="0.33"/>
    <inertia ixx="0.00125" ixy="0" ixz="0"
             iyy="0.00006" iyz="0"
             izz="0.00131"/>
  </inertial>

  <visual>
    <geometry>
      <mesh filename="package://assem1_description/meshes/Armlink1.STL"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <mesh filename="package://assem1_description/meshes/Armlink1.STL"/>
    </geometry>
  </collision>

</link>

<joint name="arm_joint1" type="revolute">

  <parent link="base_link"/>
  <child link="Armlink1"/>

  <origin xyz="0 0.07 0.49"/>
  <axis xyz="0 0 1"/>

  <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>

</joint>

<!-- ================= ARM LINK 2 ================= -->

<link name="armlink2">

  <inertial>
    <mass value="0.30"/>
    <inertia ixx="0.00075" ixy="0" ixz="0"
             iyy="0.00007" iyz="0"
             izz="0.00079"/>
  </inertial>

  <visual>
    <geometry>
      <mesh filename="package://assem1_description/meshes/armlink2.STL"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <mesh filename="package://assem1_description/meshes/armlink2.STL"/>
    </geometry>
  </collision>

</link>

<joint name="arm_joint2" type="revolute">

  <!-- 🔥 FIXED CHAIN -->
  <parent link="Armlink1"/>
  <child link="armlink2"/>

  <origin xyz="0.00077 0.265 0.47"/>
  <axis xyz="0 0 1"/>

  <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>

</joint>

</robot> 